# ============================================================
# CityBikes DE Project — Environment Variables Template
# ============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env — it is in .gitignore
# ============================================================

# --- GCP Project ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west3
GCP_ZONE=europe-west3-a

# --- GCS Bucket Names ---
# Must be globally unique across all of GCP.
# Convention: prefix + your project ID
GCS_BUCKET_RAW=citybikes-raw-your-project-id
GCS_BUCKET_PROCESSED=citybikes-processed-your-project-id
GCS_BUCKET_SNAPSHOTS=citybikes-snapshots-your-project-id

# --- BigQuery ---
BQ_DATASET_RAW=citybikes_raw
BQ_DATASET_STAGING=citybikes_staging
BQ_DATASET_MART=citybikes_mart

# --- GCP Service Account (local dev only) ---
# In Cloud Run this is handled automatically via Workload Identity
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# --- CityBikes API ---
CITYBIKES_API_BASE_URL=https://api.citybik.es/v2
CITYBIKES_NETWORKS=velib,bicing,nextbike-de,tfl-cycle-hire

# --- Storage Backend ---
# 'gcs'   = write to Google Cloud Storage (production)
# 'local' = write to local disk (development, no GCP needed)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/tmp/citybikes

# --- Kestra (local Docker Compose) ---
KESTRA_DB_USER=kestra
KESTRA_DB_PASSWORD=change_me_locally
KESTRA_DB_NAME=kestra

# --- Alerts (optional) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
